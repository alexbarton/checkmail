#!/usr/bin/env bash
#
# climail/readmail:
# Interactively select a mailbox to read mail from.
#

set -euo pipefail

usage_exit() {
	echo "Usage: $0"
	exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
	case "$1" in
	"--help")
		usage_exit 0 ;;
	*)
		usage_exit 1 >&2 ;;
	esac
done

while
	folder=$("$(dirname "$0")"/lister |
		sed -e 's/^+.//' -e 's/^+$/INBOX/' |
		fzf
	)
do
	if [[ "${folder}" = "INBOX" ]]; then
		mailbox="+"
	else
		mailbox="+.${folder}"
	fi
	"$(dirname "$0")"/openmail "${mailbox}" || exit $?
	echo
done
