#!/usr/bin/env bash
#
# climail/lister:
# Find and format a list of all mailboxes in a Maildir tree.
#

set -euo pipefail

export MAILDIR="${1:-${MAILDIR:-/var/mail/${LOGNAME}}}"

usage_exit() {
	echo "Usage: $0 [<Maildir_directory>]"
	exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
	case "$1" in
	"--help")
		usage_exit 0 ;;
	-*)
		usage_exit 1 >&2 ;;
	*)
		break
	esac
	shift
done

# Only no or one argument is supported.
[[ $# -le 1 ]] || usage_exit 1 >&2

if [[ ! -e "$MAILDIR" ]]; then
	echo "Error: \"$MAILDIR\" not found!" >&2
	exit 1
fi
if [[ ! -r "$MAILDIR" ]]; then
	echo "Error: \"$MAILDIR\" is not readable!" >&2
	exit 1
fi
if [[ ! -d "$MAILDIR/cur" || ! -d "$MAILDIR/new" ]]; then
	echo "Error: \"$MAILDIR\" seems not to be a Maildir!" >&2
	exit 1
fi
cd "$MAILDIR"

[[ -t 0 ]] && fmt="column" || fmt="cat"

find . -maxdepth 1 -type d -name '.*' |
	sed -E -e 's/^\.(\/|$)/+/' |
	sort -u |
	${fmt}
