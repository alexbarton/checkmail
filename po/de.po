#: bin/checkmail:10 bin/lister:15 bin/openmail:15 bin/readmail:15
msgid "Usage"
msgstr "Aufruf"

#: bin/checkmail:51
#, sh-format
msgid "Looking for unread mail in ${MAILDIR} ..."
msgstr "Suche nach ungelesener Mail in ${MAILDIR} ..."

#: bin/checkmail:57
msgid "No unread mail."
msgstr "Keine ungelesene Mail gefunden."

#: bin/checkmail:79
#, sh-format
msgid " (out of ${count})"
msgstr " (von ${count})"

#: bin/checkmail:85
#, sh-format
msgid "Opened one mailbox${total_info} with unread mail."
msgid_plural "Opened ${invocations} mailboxes${total_info} with unread mail."
msgstr[0] "Eine Mailbox mit ungelesener Mail wurde geöffnet${total_info}."
msgstr[1] ""
"${invocations} Mailboxen mit ungelesener Mail wurden geöffnet${total_info}."

#: bin/openmail:63
#, sh-format
msgid "Command not found: \"${cmd}\"!"
msgstr "Befehl nicht gefunden: \"${cmd}\"!"

#: bin/openmail:71
#, sh-format
msgid "Opening \"${mailbox_name}\" with ${cmd}:"
msgstr "Öffne \"${mailbox_name}\" mit ${cmd}:"

#: bin/readmail:34
msgid "Select mail folder"
msgstr "Ordner auswählen"

#: libexec/climail/climail.inc.sh:32
#, sh-format
msgid "Error: \"${MAILDIR}\" not found!"
msgstr "Fehler: \"${MAILDIR}\" nicht gefunden!"

#: libexec/climail/climail.inc.sh:36
#, sh-format
msgid "Error: \"${MAILDIR}\" is not readable!"
msgstr "Fehler: \"${MAILDIR}\" kann nicht gelesen werden!"

#: libexec/climail/climail.inc.sh:40
#, sh-format
msgid "Error: \"${MAILDIR}\" seems not to be a Maildir!"
msgstr "Fehler: \"${MAILDIR}\" scheint kein Maildir zu sein!"
