#!/usr/bin/env bash
#
# climail/lister:
# Find and format a list of all mailboxes in a Maildir tree.
#

set -euo pipefail

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
export SCRIPT_DIR
# shellcheck disable=1091
. "${SCRIPT_DIR}/../libexec/climail/climail.inc.sh"

usage_exit() {
	echo "$(gettext 'Usage'): $0 [<Maildir_directory>]"
	exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
	case "$1" in
	"--help")
		usage_exit 0 ;;
	-*)
		usage_exit 1 >&2 ;;
	*)
		break
	esac
	shift
done

# Only no or one argument is supported.
[[ $# -le 1 ]] || usage_exit 1 >&2

[[ $# -ge 1 ]] && MAILDIR="$1"
validate_maildir_or_abort

cd "$MAILDIR"

[[ -t 1 ]] && fmt="column" || fmt="cat"

find . -maxdepth 1 -type d -name '.*' |
	sed -E -e 's/^\.(\/|$)/+/' |
	sort -u |
	${fmt}
