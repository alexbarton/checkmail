#!/usr/bin/env bash
#
# climail/openmail:
# Setup and call an email client for a Maildir folder.
#

set -euo pipefail

export PAGER=${CLIMAIL_PAGER:-${PAGER:-more}}
export LISTER=${LISTER:-"$(dirname "$0")"/lister}

usage_exit() {
	echo "Usage: $0 [<mailbox> [<mailbox_command> [<arguments...>]]]"
	exit "${1:-0}"
}

get_mailbox_name() {
	if [[ "$1" = "+" ]]; then
		echo "INBOX"
	else
		echo "${1#+.}"
	fi
}

while [[ $# -gt 0 ]]; do
	case "$1" in
	"--help")
		usage_exit 0 ;;
	-*)
		usage_exit 1 >&2 ;;
	*)
		break
	esac
	shift
done

mailbox="${1:-+}"
[[ $# -ge 1 ]] && shift

# Translate folder name into proper mailbox name:
case "${mailbox}" in
"INBOX"|"inbox")
	mailbox="+" ;;
.*)
	# Leading "+" missing!?
	mailbox="+${mailbox}" ;;
[A-Za-z0-9]*)
	# Leading "+." missing!?
	mailbox="+.${mailbox}" ;;
esac

mailbox_command=("$@")

if [[ -z "${mailbox_command[0]:-}" ]]; then
	if command -v s-nail >/dev/null 2>&1; then
		mailbox_command=("s-nail" "-f")
	else
		mailbox_command=("mail" "-f")
	fi
fi
if ! command -v "${mailbox_command[0]}" >/dev/null 2>&1; then
	echo "Command not found: \"${mailbox_command[0]}\"!"
	exit 1
fi

printf 'Opening "\e[1m%s\e[0m" with %s:\n' \
	"$(get_mailbox_name "$mailbox")" "${mailbox_command[0]}"

exec "${mailbox_command[@]}" "${mailbox}"
